# ============================================================
# JojoFlix — Variables d'environnement (copier en .env)
# ============================================================

# App
APP_KEY=generate-with-node-ace-generate-key
APP_URL=http://localhost

# Database (PostgreSQL)
DB_USER=jojoflix
DB_PASSWORD=change_me_in_production
DB_DATABASE=jojoflix_db

# Redis
REDIS_PASSWORD=

# Real-Debrid
RD_API_KEY=your_real_debrid_api_key

# TMDB
TMDB_API_KEY=your_tmdb_api_key

# OpenSubtitles
OPENSUBS_API_KEY=your_opensubtitles_api_key
