# ============================================================
# JojoFlix — Variables d'environnement (copier en .env)
# ============================================================

# App
APP_KEY=generate-with-node-ace-generate-key
APP_URL=https://jojoflix.yourdomain.com
NODE_ENV=production
PORT=3333
HOST=0.0.0.0
LOG_LEVEL=info
SESSION_DRIVER=cookie

# SQLite (auth only — fichier dans le volume Docker)
DB_PATH=/data/jojoflix.sqlite

# Convex (données applicatives + cache)
CONVEX_URL=https://convex.jojoserv.com
CONVEX_ADMIN_KEY=

# Real-Debrid
RD_API_KEY=

# TMDB
TMDB_API_KEY=

# Subtitles
OPENSUBS_API_KEY=
SUBDL_API_KEY=
FLARESOLVERR_URL=http://jojoflix-flaresolverr:8191

# Sources
MEDIAFUSION_URL=
TORRENTIO_URL=https://torrentio.strem.fun
TORRENTIO_PROXY=
DRAMAYO_URL=
